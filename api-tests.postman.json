              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/departments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "departments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"school_id\": \"{{schoolId}}\",\n  \"branch_id\": \"{{branchId}}\",\n  \"name\": \"Science Department\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Department created successfully\",\n  \"data\": {\n    \"id\": \"{{departmentId}}\",\n    \"school_id\": \"{{schoolId}}\",\n    \"branch_id\": \"{{branchId}}\",\n    \"name\": \"Science Department\"\n  }\n}"
